#include <iostream>
using namespace std;
int main() {
 int sar[] = {2, 6, 8, 9, 12, 15, 18, 20};
 int i = 0;
 while (i < 8) {
 if (sar[i] % 2 == 0 && sar[i] % 3 == 0) {
 cout << sar[i] << ";";
 }
 i++;
 }
 return 0;
}
